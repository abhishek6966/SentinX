# =============================================================================
# SentinX Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
EMAIL_DOMAIN=sentinx.app

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── PostgreSQL (Supabase) ────────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── MongoDB (Atlas) ─────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://sentinx:[PASSWORD]@cluster0.xxxxx.mongodb.net/sentinx?retryWrites=true&w=majority

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Connect
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# ─── Pinecone ─────────────────────────────────────────────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=sentinx-signals
PINECONE_ENVIRONMENT=us-east-1-aws

# ─── OpenAI (Embeddings only) ────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Stock Data APIs ──────────────────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free tier)
ALPHA_VANTAGE_API_KEY=...
# Polygon.io: https://polygon.io/dashboard/api-keys (free tier)
POLYGON_API_KEY=...

# ─── News Data ────────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/account (free dev tier)
NEWSAPI_KEY=...

# ─── Social Data (Reddit OAuth2) ─────────────────────────────────────────────
# Register app: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...

# ─── Email Delivery (Resend) ─────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── AWS (Optional: S3 filing storage + SES fallback) ────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=sentinx-filings
AWS_SES_FROM_ADDRESS=alerts@sentinx.app

# ─── AI Keys (Managed via Admin Panel UI, stored encrypted in DB) ─────────────
# These are configured through /admin → AI Key Slots, not here directly.
# However for the FIRST key slot during bootstrap, set these:
GROQ_API_KEY_BOOTSTRAP=gsk_...
GEMINI_API_KEY_BOOTSTRAP=AIza...

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info
